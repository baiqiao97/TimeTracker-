<Window x:Class="TimeTracker.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册账号" Height="380" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="Transparent"
        FocusVisualStyle="{x:Null}">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Danger" Color="#ef4444"/>
        <SolidColorBrush x:Key="Success" Color="#10b981"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c5ce7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource CardBg}" CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.12"/>
        </Border.Effect>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="创建账号" FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                <Button Content="✕" Click="BtnClose_Click" Width="32" Height="32"
                        HorizontalAlignment="Right" FontSize="14" Background="Transparent"
                        Foreground="#9ca3af" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <TextBlock Grid.Row="0" Text="注册后将自动登录并启用云同步"
                       FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,40,0,16"/>

            <!-- Username -->
            <TextBlock Grid.Row="1" Text="用户名" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
            <Grid Grid.Row="2" Margin="0,0,0,4">
                <TextBox x:Name="txtUsername" TextChanged="TxtUsername_TextChanged"/>
                <TextBlock x:Name="lblUsernameHint" Text="" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,14,6"/>
            </Grid>

            <!-- Password -->
            <TextBlock Grid.Row="3" Text="密码" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
            <Grid Grid.Row="4" Margin="0,0,0,4">
                <TextBox x:Name="txtPassword" TextChanged="TxtPassword_TextChanged"/>
                <TextBlock x:Name="lblPasswordHint" Text="" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,14,6"/>
            </Grid>

            <!-- Error message -->
            <TextBlock Grid.Row="5" x:Name="lblError" Text="" FontSize="12"
                       Foreground="{StaticResource Danger}" Margin="0,4,0,8" TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="6" VerticalAlignment="Bottom" Margin="0,8,0,0">
                <Button x:Name="btnRegister" Content="注册" Click="BtnRegister_Click"
                        Height="42" FontSize="14" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Background" Value="#a5b4fc"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock x:Name="runMinHint" FontSize="11" Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           Text="用户名和密码至少 6 位"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
