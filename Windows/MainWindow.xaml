<Window x:Class="TimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeTracker" Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FocusVisualStyle="{x:Null}">

    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="SidebarBg" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="SidebarHover" Color="#262a3e"/>
        <SolidColorBrush x:Key="SidebarActive" Color="#333a56"/>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="AccentLight" Color="#a29bfe"/>
        <SolidColorBrush x:Key="Bg" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="Success" Color="#10b981"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Danger" Color="#ef4444"/>
        <SolidColorBrush x:Key="Info" Color="#3b82f6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
        <DropShadowEffect x:Key="HoverShadow" BlurRadius="30" ShadowDepth="2" Opacity="0.12" Color="#000000"/>

        <!-- Button Style -->
        <Style TargetType="Button" x:Key="SidebarBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0aec0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                Margin="8,1,8,1">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#262a3e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#6c5ce7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a4bd1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GhostBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f9fafb"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#9ca3af"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#f8fafc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#f3f4f6" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="cellBorder" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="cellBorder" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1a1d2e"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f3f4f6"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1a1d2e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Window Chrome -->
    <Border Background="{StaticResource Bg}" CornerRadius="0" x:Name="mainBorder" FocusVisualStyle="{x:Null}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Border Grid.Row="0" Padding="20,24,20,20">
                        <StackPanel>
                            <TextBlock Text="TimeTracker" FontSize="20" FontWeight="Bold"
                                       Foreground="White" FontFamily="Segoe UI"/>
                            <TextBlock Text="智能时间管理" FontSize="11"
                                       Foreground="#a0aec0" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <Button x:Name="btnOverview" Content="📊  概览" Style="{StaticResource SidebarBtn}"
                                Click="NavOverview_Click"/>
                        <Button x:Name="btnDaily" Content="📅  每日" Style="{StaticResource SidebarBtn}"
                                Click="NavDaily_Click"/>
                        <Button x:Name="btnWeekly" Content="📆  每周" Style="{StaticResource SidebarBtn}"
                                Click="NavWeekly_Click"/>
                        <Button x:Name="btnCategory" Content="🏷️  分类统计" Style="{StaticResource SidebarBtn}"
                                Click="NavCategory_Click"/>

                        <Separator Background="#333a56" Height="1" Margin="16,12,16,8" Opacity="0.5"/>

                        <Button Content="📥  导入" Style="{StaticResource SidebarBtn}"
                                Click="NavImport_Click"/>
                        <Button Content="📤  导出" Style="{StaticResource SidebarBtn}"
                                Click="NavExport_Click"/>
                        <Button Content="🔄  同步" Style="{StaticResource SidebarBtn}"
                                Click="NavSync_Click"/>

                        <Separator Background="#333a56" Height="1" Margin="16,12,16,8" Opacity="0.5"/>

                        <Button Content="🏷️  管理标签" Style="{StaticResource SidebarBtn}"
                                Click="NavManageCategories_Click"/>
                    </StackPanel>

                    <!-- Bottom -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,16">
                        <Button Content="⚙️  设置" Style="{StaticResource SidebarBtn}"
                                Click="NavSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Column="1" Margin="24,16,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="lblPageTitle" Text="概览" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock x:Name="lblPageSubtitle" Text="今日应用使用总览"
                                       FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <ComboBox x:Name="cmbActivity" Width="140" Height="32" FontSize="12"
                                      VerticalContentAlignment="Center" Padding="8,0"
                                      SelectionChanged="CmbActivity_Changed" ToolTip="当前活动（活动模式）"/>
                            <Button x:Name="btnAddActivity" Content="+" Width="28" Height="28" FontSize="16"
                                    Background="Transparent" BorderThickness="0" Foreground="#6b7280"
                                    Cursor="Hand" ToolTip="新建活动" Click="BtnAddActivity_Click" Margin="2,0,0,0"
                                    FocusVisualStyle="{x:Null}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Quick Stats Row -->
                        <Grid x:Name="statsPanel" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Total Usage Card -->
                            <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="14"
                                    Padding="20" Margin="0,0,8,0" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="总使用时长" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="lblTotalTime" Text="--" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                                    <TextBlock x:Name="lblDateRange" Text="今日" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Tracked Apps Card -->
                            <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="14"
                                    Padding="20" Margin="4,0,4,0" Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="追踪应用" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBlock x:Name="lblAppCount" Text="--" FontSize="28" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}" Margin="0,4,0,0"/>
                                    <TextBlock Text="个应用" FontSize="11"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Active Time Card -->
                            <Border Grid.Column="2" Background="{StaticResource CardBg}" CornerRadius="14"
                                    Padding="20" Margin="8,0,0,0" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="活跃状态" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Ellipse x:Name="statusDot" Width="10" Height="10" Fill="{StaticResource Success}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="lblStatus" Text="追踪中" FontSize="20" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Success}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="lblCurrentApp" Text="就绪" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="btnPause" Grid.Column="1" Content="⏸" Width="40" Height="40"
                                            FontSize="18" Background="#f0f2f5" BorderThickness="0"
                                            Cursor="Hand" Click="BtnPause_Click" VerticalAlignment="Center"
                                            ToolTip="暂停/恢复追踪">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        CornerRadius="20">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#e2e5ea"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Action Buttons Row -->
                        <StackPanel x:Name="actionPanel" Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="每日" x:Name="btnActionDaily" Style="{StaticResource GhostBtn}"
                                    Click="ActionDaily_Click" Margin="0,0,6,0"/>
                            <Button Content="每周" Style="{StaticResource GhostBtn}"
                                    Click="ActionWeekly_Click" Margin="0,0,6,0"/>
                            <Button Content="每月" Style="{StaticResource GhostBtn}"
                                    Click="ActionMonthly_Click" Margin="0,0,6,0"/>
                            <Button Content="分类统计" Style="{StaticResource GhostBtn}"
                                    Click="ActionCategory_Click" Margin="0,0,6,0"/>
                            <Button Content="前台/后台" Style="{StaticResource GhostBtn}"
                                    Click="ActionForeground_Click"/>
                            <Button Content="📊 图表" Style="{StaticResource GhostBtn}"
                                    Click="ActionChart_Click"/>
                        </StackPanel>

                        <!-- Data Table Card -->
                        <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="4"
                                Effect="{StaticResource CardShadow}">
                            <DataGrid x:Name="dataGrid" AutoGenerateColumns="False" Height="280"
                                      MouseDoubleClick="DataGrid_MouseDoubleClick"
                                      SelectionChanged="DataGrid_SelectionChanged">
                                <!-- Columns set dynamically -->
                            </DataGrid>
                        </Border>

                        <!-- Chart Area -->
                        <Border x:Name="chartBorder" Background="{StaticResource CardBg}" CornerRadius="14"
                                Padding="20" Margin="0,16,0,0" Effect="{StaticResource CardShadow}" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="📊 使用统计图表" FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    <Button Content="关闭" Style="{StaticResource GhostBtn}" Margin="12,0,0,0"
                                            Click="ChartClose_Click"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Top 10 柱状图" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                            <Canvas x:Name="barChartCanvas" Grid.Row="1" Height="220"
                                                    Background="Transparent" ClipToBounds="True"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Margin="8,0,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="标签分类占比" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                            <Canvas x:Name="pieChartCanvas" Grid.Row="1" Height="220"
                                                    Background="Transparent" ClipToBounds="True"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
