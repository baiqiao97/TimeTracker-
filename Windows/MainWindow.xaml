<Window x:Class="TimeTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeTracker" Height="720" Width="1100"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        FocusVisualStyle="{x:Null}">

    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="SidebarBg" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="SidebarTop" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="AccentLight" Color="#a29bfe"/>
        <SolidColorBrush x:Key="AccentDark" Color="#5a4bd1"/>
        <SolidColorBrush x:Key="Bg" Color="#f5f6fa"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="Success" Color="#10b981"/>
        <SolidColorBrush x:Key="SuccessBg" Color="#ecfdf5"/>
        <SolidColorBrush x:Key="Warning" Color="#f59e0b"/>
        <SolidColorBrush x:Key="Danger" Color="#ef4444"/>
        <SolidColorBrush x:Key="Info" Color="#3b82f6"/>
        <SolidColorBrush x:Key="Indigo" Color="#6366f1"/>
        <SolidColorBrush x:Key="Pink" Color="#ec4899"/>
        <SolidColorBrush x:Key="Teal" Color="#14b8a6"/>
        <SolidColorBrush x:Key="Amber" Color="#f59e0b"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
        <DropShadowEffect x:Key="SidebarShadow" BlurRadius="0" ShadowDepth="4" Opacity="0.1" Color="#000000"/>

        <!-- Sidebar Navigation Button Style -->
        <Style TargetType="Button" x:Key="SidebarBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0aec0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="20,0,16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="10" Padding="{TemplateBinding Padding}"
                                Margin="8,1,8,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="indicator" Grid.Column="0" Background="Transparent"
                                        CornerRadius="2" Margin="-4,0,0,0" Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252a3e"/>
                                <Setter Property="Foreground" Value="#e2e8f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SidebarBtnActive" BasedOn="{StaticResource SidebarBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#6c5ce7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#6c5ce7" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Color="#6c5ce7"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5a4bd1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GhostBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#f3f4f6"/>
                                <Setter Property="Foreground" Value="#1a1d2e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TagBtn">
            <Setter Property="Background" Value="#f3f4f6"/>
            <Setter Property="Foreground" Value="#6c5ce7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#f3f4f6" CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e8e4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrioBtn">
            <Setter Property="Background" Value="#f3f4f6"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#f3f4f6" CornerRadius="10"
                                Padding="0" BorderThickness="2" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e8e4ff"/>
                                <Setter Property="Foreground" Value="#6c5ce7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrioBtnHigh" BasedOn="{StaticResource PrioBtn}">
            <Setter Property="Background" Value="#fef2f2"/>
            <Setter Property="Foreground" Value="#ef4444"/>
        </Style>
        <Style TargetType="Button" x:Key="PrioBtnMid" BasedOn="{StaticResource PrioBtn}">
            <Setter Property="Background" Value="#fffbeb"/>
            <Setter Property="Foreground" Value="#f59e0b"/>
        </Style>
        <Style TargetType="Button" x:Key="PrioBtnLow" BasedOn="{StaticResource PrioBtn}">
            <Setter Property="Background" Value="#ecfdf5"/>
            <Setter Property="Foreground" Value="#10b981"/>
        </Style>

        <Style TargetType="Button" x:Key="PrioBtnHighActive" BasedOn="{StaticResource PrioBtnHigh}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#fef2f2" CornerRadius="10"
                                Padding="0" BorderThickness="2" BorderBrush="#ef4444">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PrioBtnMidActive" BasedOn="{StaticResource PrioBtnMid}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#fffbeb" CornerRadius="10"
                                Padding="0" BorderThickness="2" BorderBrush="#f59e0b">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PrioBtnLowActive" BasedOn="{StaticResource PrioBtnLow}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#ecfdf5" CornerRadius="10"
                                Padding="0" BorderThickness="2" BorderBrush="#10b981">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ColorPickerBtn">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ring" CornerRadius="15" BorderThickness="2"
                                    BorderBrush="Transparent" Background="Transparent"
                                    Width="28" Height="28"/>
                            <Border x:Name="dot" CornerRadius="9" Width="18" Height="18"
                                    Background="{TemplateBinding Background}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="BorderBrush"
                                        Value="{Binding Background, ElementName=dot}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ColorPickerBtnSelected" BasedOn="{StaticResource ColorPickerBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ring" CornerRadius="15" BorderThickness="2"
                                    BorderBrush="{TemplateBinding Background}"
                                    Background="Transparent" Width="28" Height="28"/>
                            <Border x:Name="dot" CornerRadius="9" Width="18" Height="18"
                                    Background="{TemplateBinding Background}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DateBtn">
            <Setter Property="Background" Value="#f3f4f6"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#f3f4f6" CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txt" Text="选择日期" VerticalAlignment="Center"
                                           Foreground="#6b7280"/>
                                <TextBlock Text="📅" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e8e4ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" x:Key="ModernComboStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Setter Property="Background" Value="#f3f4f6"/>
            <Setter Property="BorderBrush" Value="#e5e7eb"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Grid.Column="2"
                                          Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource FindAncestor, AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                                                  TextBlock.FontSize="12" TextBlock.Foreground="#1a1d2e"/>
                                                <TextBlock Grid.Column="1" x:Name="Arrow" Text="▾"
                                                           FontSize="10" Foreground="#9ca3af"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#e8e4ff"/>
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#6c5ce7"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#ede9fe"/>
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#6c5ce7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder" Background="White"
                                        CornerRadius="12" Margin="0,4,0,0"
                                        BorderBrush="#e5e7eb" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="2"
                                                          Opacity="0.12" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="#1a1d2e"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder" Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#f3f4f6"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#ede9fe"/>
                                            <Setter Property="Foreground" Value="#6c5ce7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#f8fafc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="48"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="Transparent"
                                BorderBrush="#f3f4f6" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#1a1d2e"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f8f9fb"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Bg}" CornerRadius="12" x:Name="mainBorder">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.12"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Border Grid.Column="0" CornerRadius="12,0,0,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1a1d2e" Offset="0"/>
                        <GradientStop Color="#1f2347" Offset="0.5"/>
                        <GradientStop Color="#1a1d2e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Margin="24,28,24,8">
                        <TextBlock Text="TimeTracker" FontSize="22" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="时间管理专家" FontSize="11"
                                   Foreground="#7c8db5" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Section: 统计 -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="数据统计" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748b" Margin="24,0,0,6" TextOptions.TextFormattingMode="Display"/>
                        <Button x:Name="btnOverview" Content="📊  概览" Style="{StaticResource SidebarBtn}" Click="NavOverview_Click"/>
                        <Button x:Name="btnDaily" Content="📅  每日" Style="{StaticResource SidebarBtn}" Click="NavDaily_Click"/>
                        <Button x:Name="btnWeekly" Content="📆  每周" Style="{StaticResource SidebarBtn}" Click="NavWeekly_Click"/>
                        <Button x:Name="btnCategory" Content="🏷  分类统计" Style="{StaticResource SidebarBtn}" Click="NavCategory_Click"/>
                        <Button x:Name="btnActivity" Content="🎯  活动统计" Style="{StaticResource SidebarBtn}" Click="NavActivity_Click" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Section: 工具 -->
                    <StackPanel x:Name="panelTools" Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="效率工具" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748b" Margin="24,0,0,6" TextOptions.TextFormattingMode="Display"/>
                        <Button x:Name="btnTodoList" Content="✅ 待办清单" Style="{StaticResource SidebarBtn}" Click="NavTodoList_Click"/>
                        <Button x:Name="btnSchedule" Content="📅 日程安排" Style="{StaticResource SidebarBtn}" Click="NavSchedule_Click"/>
                    </StackPanel>

                    <!-- Section: 数据 (标准模式) -->
                    <StackPanel x:Name="panelStandard" Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Text="数据管理" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748b" Margin="24,0,0,6" TextOptions.TextFormattingMode="Display"/>
                        <Button Content="📥  导入" Style="{StaticResource SidebarBtn}" Click="NavImport_Click"/>
                        <Button Content="📤  导出" Style="{StaticResource SidebarBtn}" Click="NavExport_Click"/>
                        <Button Content="🔄  同步" Style="{StaticResource SidebarBtn}" Click="NavSync_Click"/>
                        <Button Content="🏷  管理标签" Style="{StaticResource SidebarBtn}" Click="NavManageCategories_Click"/>
                    </StackPanel>

                    <!-- Section: 数据 (活动模式) -->
                    <StackPanel x:Name="panelActivity" Grid.Row="3" Margin="0,16,0,0" Visibility="Collapsed">
                        <TextBlock Text="活动管理" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#64748b" Margin="24,0,0,6" TextOptions.TextFormattingMode="Display"/>
                        <Button Content="📥  导入" Style="{StaticResource SidebarBtn}" Click="NavImport_Click"/>
                        <Button Content="📤  导出" Style="{StaticResource SidebarBtn}" Click="NavExport_Click"/>
                        <Button Content="🔄  同步" Style="{StaticResource SidebarBtn}" Click="NavSync_Click"/>
                        <Button Content="🎯  管理活动" Style="{StaticResource SidebarBtn}" Click="NavManageActivities_Click"/>
                        <Button Content="🏷  管理标签" Style="{StaticResource SidebarBtn}" Click="NavManageCategories_Click"/>
                    </StackPanel>

                    <!-- Bottom -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,20">
                        <Button Content="⚙  设置" Style="{StaticResource SidebarBtn}" Click="NavSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== MAIN CONTENT ===== -->
            <Grid Grid.Column="1" Margin="28,20,28,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,4,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="lblPageTitle" Text="概览" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="lblPageSubtitle" Text="今日应用使用总览"
                                   FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                    </StackPanel>
                    <StackPanel x:Name="activityPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Visibility="Collapsed">
                        <ComboBox x:Name="cmbActivity" Width="150"
                                  Style="{StaticResource ModernComboStyle}"
                                  SelectionChanged="CmbActivity_Changed" ToolTip="切换当前活动"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Quick Stats Row -->
                    <Grid x:Name="statsPanel" Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="150"/>
                                <ColumnDefinition Width="*" MinWidth="120"/>
                                <ColumnDefinition Width="*" MinWidth="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- Total Usage Card -->
                            <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="16"
                                    Padding="22" Margin="0,0,8,0" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Height="3" CornerRadius="2" Background="#6c5ce7" Margin="-22,-22,-22,0"/>
                                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                        <TextBlock Text="总使用时长" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="lblTotalTime" Text="--" FontSize="30" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" Margin="0,6,0,0"/>
                                        <TextBlock x:Name="lblDateRange" Text="今日" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Tracked Apps Card -->
                            <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="16"
                                    Padding="22" Margin="4,0,4,0" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Height="3" CornerRadius="2" Background="#6366f1" Margin="-22,-22,-22,0"/>
                                    <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                        <TextBlock Text="追踪应用" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBlock x:Name="lblAppCount" Text="--" FontSize="30" FontWeight="Bold"
                                                   Foreground="#6366f1" Margin="0,6,0,0"/>
                                        <TextBlock Text="个应用" FontSize="11"
                                                   Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Active Time Card -->
                            <Border Grid.Column="2" Background="{StaticResource CardBg}" CornerRadius="16"
                                    Padding="22" Margin="8,0,0,0" Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Height="3" CornerRadius="2" Background="#10b981" Margin="-22,-22,-22,0"/>
                                    <Grid Grid.Row="1" Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="活跃状态" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse x:Name="statusDot" Width="10" Height="10" Fill="#10b981"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="lblStatus" Text="追踪中" FontSize="22" FontWeight="SemiBold"
                                                           Foreground="#10b981"/>
                                            </StackPanel>
                                            <TextBlock x:Name="lblCurrentApp" Text="就绪" FontSize="12"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="btnPause" Grid.Column="1" Content="⏸" Width="44" Height="44"
                                                FontSize="18" Background="#f5f6fa" BorderThickness="0"
                                                Cursor="Hand" Click="BtnPause_Click" VerticalAlignment="Center"
                                                ToolTip="暂停/恢复追踪">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="#f5f6fa" CornerRadius="22">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#e8e4ff"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Action Buttons Row -->
                        <Grid x:Name="actionPanel" Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="每日" x:Name="btnActionDaily" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="ActionDaily_Click"/>
                                <Button Content="每周" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="ActionWeekly_Click"/>
                                <Button Content="每月" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="ActionMonthly_Click"/>
                                <Button Content="分类统计" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="ActionCategory_Click"/>
                            <Button Content="前台/后台" Style="{StaticResource TagBtn}" Click="ActionForeground_Click"/>
                            <Button Content="🕐 时间线" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="ActionTimeline_Click"/>
                            <Button Content="📊 图表" Style="{StaticResource PrimaryBtn}" Margin="16,0,0,0" Click="ActionChart_Click"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#f9fafb" CornerRadius="8" Padding="2,0"
                                    BorderBrush="#e5e7eb" BorderThickness="1" Width="200">
                                <TextBox x:Name="txtSearch" FontSize="12" Padding="8,6"
                                         Background="Transparent" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged"
                                         ToolTip="搜索应用名、标签、窗口标题"/>
                            </Border>
                        </Grid>

                        <!-- Data Table Card -->
                        <Border x:Name="contentBorder" Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="16" Padding="6"
                                Effect="{StaticResource CardShadow}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          PanningMode="VerticalOnly" CanContentScroll="False">
                                <StackPanel>
                                    <DataGrid x:Name="dataGrid" AutoGenerateColumns="False"
                                              MinHeight="100"
                                              MouseDoubleClick="DataGrid_MouseDoubleClick"
                                              SelectionChanged="DataGrid_SelectionChanged"/>

                                    <!-- Chart Area -->
                                    <Border x:Name="chartBorder" Background="{StaticResource CardBg}" CornerRadius="16"
                                            Padding="24" Margin="0,16,0,0" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="📊 使用统计图表" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    <Button Content="关闭图表" Style="{StaticResource GhostBtn}" Margin="16,0,0,0"
                                            Click="ChartClose_Click"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#fafbfc" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Top 10 应用耗时" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                                            <Canvas x:Name="barChartCanvas" Grid.Row="1" MinHeight="180"
                                                    Background="Transparent" ClipToBounds="True"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" Background="#fafbfc" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="标签分类占比" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
                                            <Canvas x:Name="pieChartCanvas" Grid.Row="1" MinHeight="180"
                                                    Background="Transparent" ClipToBounds="True"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

                    <!-- TodoList Panel -->
                    <Grid x:Name="todoPanel" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox x:Name="txtTodoTitle" Width="280" Height="38" FontSize="13"
                                     VerticalContentAlignment="Center" Padding="12,0"
                                     BorderBrush="#e5e7eb" BorderThickness="1"
                                     ToolTip="输入新待办事项" Margin="0,0,8,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Button x:Name="btnPrioHigh" Content="高" Style="{StaticResource PrioBtnHigh}" Tag="2"
                                        Click="Priority_Click"/>
                                <Button x:Name="btnPrioMid" Content="中" Style="{StaticResource PrioBtnMidActive}" Tag="1"
                                        Click="Priority_Click"/>
                                <Button x:Name="btnPrioLow" Content="低" Style="{StaticResource PrioBtnLow}" Tag="0"
                                        Click="Priority_Click"/>
                            </StackPanel>
                            <Button Content="添加" Style="{StaticResource PrimaryBtn}" Click="TodoAdd_Click"/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,12">
                            <Button x:Name="btnTodoFilterAll" Content="全部" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="TodoFilterAll_Click"/>
                            <Button x:Name="btnTodoFilterPending" Content="进行中" Style="{StaticResource TagBtn}" Margin="0,0,6,0" Click="TodoFilterPending_Click"/>
                            <Button x:Name="btnTodoFilterDone" Content="已完成" Style="{StaticResource TagBtn}" Click="TodoFilterDone_Click"/>
                        </WrapPanel>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="todoItemsControl"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- Schedule Panel -->
                    <Grid x:Name="schedulePanel" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox x:Name="txtScheduleTitle" Width="180" Height="38" FontSize="13"
                                     VerticalContentAlignment="Center" Padding="12,0"
                                     BorderBrush="#e5e7eb" BorderThickness="1"
                                     Margin="0,0,8,0" ToolTip="日程标题"/>
                            <Button x:Name="btnDatePicker" Width="150" Height="38"
                                    Style="{StaticResource DateBtn}" Margin="0,0,8,0" Click="DatePickerBtn_Click"/>
                            <DatePicker x:Name="dpScheduleDate" Visibility="Collapsed"
                                        SelectedDateChanged="DatePicker_Changed"/>
                            <TextBox x:Name="txtScheduleTime" Width="170" Height="38" FontSize="12"
                                     VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#e5e7eb" BorderThickness="1"
                                     Margin="0,0,8,0" Text="08:00 - 10:00" ToolTip="开始-结束时间"/>
                            <CheckBox x:Name="chkAllDay" Content="全天" VerticalAlignment="Center" FontSize="12"
                                      Margin="0,0,10,0"/>
                            <StackPanel x:Name="colorPickerGroup" Orientation="Horizontal" Margin="0,0,10,0"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnColor1" Background="#6c5ce7" Tag="#6c5ce7" Click="Color_Click"
                                        Style="{StaticResource ColorPickerBtnSelected}"/>
                                <Button x:Name="btnColor2" Background="#10b981" Tag="#10b981" Click="Color_Click"
                                        Style="{StaticResource ColorPickerBtn}"/>
                                <Button x:Name="btnColor3" Background="#f59e0b" Tag="#f59e0b" Click="Color_Click"
                                        Style="{StaticResource ColorPickerBtn}"/>
                                <Button x:Name="btnColor4" Background="#ef4444" Tag="#ef4444" Click="Color_Click"
                                        Style="{StaticResource ColorPickerBtn}"/>
                                <Button x:Name="btnColor5" Background="#3b82f6" Tag="#3b82f6" Click="Color_Click"
                                        Style="{StaticResource ColorPickerBtn}"/>
                            </StackPanel>
                            <Button Content="添加" Style="{StaticResource PrimaryBtn}" Click="ScheduleAdd_Click"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="scheduleItemsControl"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
        </Grid>
        </Grid>
    </Border>
</Window>
