<Window x:Class="TimeTracker.GoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="目标管理" Height="620" Width="800"
        WindowStartupLocation="CenterOwner" Background="#f5f6fa"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="🎯 目标管理" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="设定目标 → AI 拆解阶段 → 追踪进度 → 检测有效工作时间" FontSize="12"
                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 新建目标 -->
        <Border Grid.Row="1" Background="{StaticResource CardBg}" CornerRadius="14" Padding="20"
                Effect="{StaticResource CardShadow}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="设定新目标" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtGoal" FontSize="14" Padding="10,8" Background="#f9fafb"
                             BorderBrush="#d1d5db" BorderThickness="1" ToolTip="例如：三个月内学会 Python 数据分析"/>
                </StackPanel>
                <Button x:Name="btnAiDecompose" Grid.Column="1" Content="🤖 AI 拆解" Click="BtnAiDecompose_Click" Width="100" Height="38"
                        Background="#6c5ce7" Foreground="White" FontSize="12" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Margin="10,22,4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#5a4bd1"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="2" Content="添加目标" Click="BtnAddGoal_Click" Width="90" Height="38"
                        Background="#10b981" Foreground="White" FontSize="12" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Margin="4,22,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#10b981" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#059669"/></Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- AI 密钥设置行 -->
        <Border Grid.Row="1" Background="#fffbeb" CornerRadius="10" Padding="12,8"
                Margin="0,72,0,0" x:Name="borderApiHint" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠ 需配置 AI API Key（设置 → AI 接口）" FontSize="11" Foreground="#f59e0b"
                           VerticalAlignment="Center"/>
                <Button Content="配置" FontSize="11" Foreground="#6c5ce7" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Click="BtnConfigAi_Click" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 目标列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="lstGoals"/>
        </ScrollViewer>
    </Grid>
</Window>
