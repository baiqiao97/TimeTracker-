<Window x:Class="TimeTracker.CategoryManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理标签" Height="620" Width="760"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="#f5f6fa">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c5ce7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 颜色圆点按钮 -->
        <Style x:Key="ColorDot" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="dot" Fill="{TemplateBinding Tag}" Width="24" Height="24"/>
                            <Ellipse x:Name="ring" Stroke="Transparent" StrokeThickness="2" Width="30" Height="30"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="Stroke" Value="{TemplateBinding Tag}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabItem Header 样式 -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" Background="Transparent"
                                CornerRadius="10,10,0,0" Padding="16,10"
                                Cursor="Hand" Margin="2,0,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#6c5ce7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{StaticResource CardBg}" CornerRadius="14,14,0,0"
                Margin="12,12,12,0" Padding="20,16" Effect="{StaticResource CardShadow}">
            <TextBlock Text="标签与分类管理" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
        </Border>

        <!-- 内容 -->
        <Border Grid.Row="1" Background="{StaticResource CardBg}" CornerRadius="0,0,14,14"
                Margin="12,0,12,12" Padding="4,0,4,4">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem FontSize="13" FontWeight="SemiBold">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#6c5ce7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="标签管理"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="290"/>
                        </Grid.ColumnDefinitions>

                        <!-- 标签列表 -->
                        <Border Grid.Column="0" Background="#fafbfc" CornerRadius="12" Padding="6"
                                Margin="0,0,12,0">
                            <ListBox x:Name="lstCategories" BorderThickness="0" Background="Transparent"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,1">
                                            <Border x:Name="rowBorder" Padding="12,10" CornerRadius="10"
                                                    Background="Transparent"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="16" Height="16" Fill="{Binding ColorBrush}"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="{Binding Color}" FontSize="10" Margin="8,0,0,0"
                                                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondary}" Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="编辑" FontSize="11" FontWeight="SemiBold"
                                                        Foreground="#6c5ce7" Background="Transparent"
                                                        BorderThickness="0" Padding="10,6"
                                                        Click="Edit_Click" Tag="{Binding Id}" Cursor="Hand"/>
                                                <Button Grid.Column="3" Content="删除" FontSize="11" FontWeight="SemiBold"
                                                        Foreground="#ef4444" Background="Transparent"
                                                        BorderThickness="0" Padding="10,6"
                                                        Click="Delete_Click" Tag="{Binding Id}" Cursor="Hand"/>
                                            </Grid>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                <Setter TargetName="rowBorder" Property="Background" Value="#f5f6fa"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- 添加/编辑表单 -->
                        <Border Grid.Column="1" Background="#fafbfc" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock x:Name="lblFormTitle" Text="添加新标签" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,18"/>

                                <TextBlock Text="标签名称" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtName" Margin="0,0,0,14"/>

                                <TextBlock Text="颜色" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtColor" Text="#6c5ce7" Margin="0,0,6,0"/>
                                    <Border Grid.Column="1" x:Name="colorPreview" Width="38" Height="38"
                                            CornerRadius="8" Background="#6c5ce7"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <WrapPanel Margin="0,4,0,14">
                                    <Button Tag="#6c5ce7" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#ef4444" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#10b981" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#f59e0b" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#3b82f6" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#8b5cf6" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#3498db" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                    <Button Tag="#ec4899" Click="PresetColor_Click" Style="{StaticResource ColorDot}"/>
                                </WrapPanel>

                                <TextBlock Text="描述（可选）" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtDesc" Margin="0,0,0,18"/>

                                <Button x:Name="btnSave" Content="添加标签" Click="Save_Click"
                                        Height="42" FontSize="13" FontWeight="SemiBold"
                                        Foreground="White" BorderThickness="0" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button x:Name="btnCancel" Content="取消" Click="Cancel_Click"
                                        Background="#f3f4f6" Foreground="#6b7280" FontSize="12"
                                        Height="36" BorderThickness="0" Cursor="Hand" Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#f3f4f6" CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem FontSize="13" FontWeight="SemiBold">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#10b981" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="应用标签分配"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="16">
                        <Border Background="#fafbfc" CornerRadius="12" Padding="12">
                            <ListBox x:Name="lstProcessMap" BorderThickness="0" Background="Transparent"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Border x:Name="rowBorder" Padding="12,10" CornerRadius="8"
                                                    Background="Transparent"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                                               FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"
                                                               ToolTip="{Binding ProcessName}"/>
                                                    <TextBlock Text="{Binding ProcessName}" FontSize="10"
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="#ede9fe" CornerRadius="20"
                                                        Padding="10,3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding UsageDisplay}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#6c5ce7"/>
                                                </Border>
                                                <ComboBox Grid.Column="2" Width="170" Height="32" Margin="16,0,0,0"
                                                          ItemsSource="{Binding AvailableCategories}"
                                                          SelectedValue="{Binding CategoryId, Mode=TwoWay}"
                                                          DisplayMemberPath="Name" SelectedValuePath="Id"
                                                          SelectionChanged="ProcessCategory_SelectionChanged"/>
                                            </Grid>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                <Setter TargetName="rowBorder" Property="Background" Value="#f5f6fa"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
