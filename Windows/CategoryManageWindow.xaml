<Window x:Class="TimeTracker.CategoryManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理标签" Height="580" Width="700"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="#f0f2f5">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c5ce7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl Margin="0" Background="Transparent" BorderThickness="0">
        <TabItem Header="  标签管理  " FontSize="13">
            <Grid Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- 标签列表 -->
                <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="12" Padding="4"
                        Effect="{StaticResource CardShadow}" Margin="0,0,12,0">
                    <ListBox x:Name="lstCategories" BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="2,1" CornerRadius="8"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="14" Height="14" Fill="{Binding ColorBrush}"
                                                 VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondary}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="编辑" FontSize="11"
                                                Foreground="#6c5ce7" Background="Transparent"
                                                BorderThickness="0" Padding="8,4"
                                                Click="Edit_Click" Tag="{Binding Id}" Cursor="Hand"/>
                                        <Button Grid.Column="3" Content="删除" FontSize="11"
                                                Foreground="#ef4444" Background="Transparent"
                                                BorderThickness="0" Padding="8,4"
                                                Click="Delete_Click" Tag="{Binding Id}" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- 添加/编辑表单 -->
                <Border Grid.Column="1" Background="{StaticResource CardBg}" CornerRadius="12" Padding="20"
                        Effect="{StaticResource CardShadow}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock x:Name="lblFormTitle" Text="添加新标签" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                        <TextBlock Text="标签名称" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtName" Margin="0,0,0,12"/>

                        <TextBlock Text="颜色" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtColor" Margin="0,0,0,8"/>

                        <WrapPanel>
                            <Button Width="24" Height="24" Margin="1" Tag="#6c5ce7" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#6c5ce7"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#ef4444" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#ef4444"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#10b981" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#10b981"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#f59e0b" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#f59e0b"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#3b82f6" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#3b82f6"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#8b5cf6" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#8b5cf6"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#3498db" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#3498db"/></ControlTemplate></Button.Template></Button>
                            <Button Width="24" Height="24" Margin="1" Tag="#34495e" Click="PresetColor_Click" Cursor="Hand">
                                <Button.Template><ControlTemplate TargetType="Button"><Ellipse Width="20" Height="20" Fill="#34495e"/></ControlTemplate></Button.Template></Button>
                        </WrapPanel>

                        <TextBlock Text="描述（可选）" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,4"/>
                        <TextBox x:Name="txtDesc" Margin="0,0,0,16"/>

                        <Button x:Name="btnSave" Content="添加标签" Click="Save_Click"
                                Background="#6c5ce7" Foreground="White" FontSize="13" FontWeight="SemiBold"
                                Height="40" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="btnCancel" Content="取消" Click="Cancel_Click"
                                Background="#f3f4f6" Foreground="#6b7280" FontSize="12"
                                Height="36" BorderThickness="0" Cursor="Hand" Margin="0,8,0,0"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <TabItem Header="  应用标签分配  " FontSize="13">
            <Grid Margin="16">
                <Border Background="{StaticResource CardBg}" CornerRadius="12" Padding="12"
                        Effect="{StaticResource CardShadow}">
                    <ListBox x:Name="lstProcessMap" BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,4" Margin="0,1" CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="13"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   ToolTip="{Binding ProcessName}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UsageDisplay}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="2" Width="180" Height="30"
                                                  ItemsSource="{Binding AvailableCategories}"
                                                  SelectedValue="{Binding CategoryId, Mode=TwoWay}"
                                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                                  SelectionChanged="ProcessCategory_SelectionChanged"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
