<Window x:Class="TimeTracker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="640" Width="460"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="#f0f2f5">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c5ce7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Background="{StaticResource CardBg}" CornerRadius="12" Margin="16"
            Padding="24" Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="追踪设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="追踪间隔（秒）" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtInterval" Text="2" Margin="0,0,0,16"/>

                <TextBlock Text="数据保留（天）" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRetentionDays" Text="90" Margin="0,0,0,16"/>

                <CheckBox x:Name="chkAutoStart" Content="开机自动启动"
                          FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>

                <TextBlock Text="追踪模式" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton x:Name="rbSimple" Content="标准模式" GroupName="trackMode"
                                 FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,16,0"/>
                    <RadioButton x:Name="rbActivity" Content="活动模式" GroupName="trackMode"
                                 FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <TextBlock Text="云同步" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBox x:Name="txtUsername" Text="" Width="140" Margin="0,0,6,0"
                             ToolTip="用户名"/>
                    <TextBox x:Name="txtPassword" Text="" Width="140" Margin="0,0,6,0"
                             ToolTip="密码"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button Content="注册" Click="BtnRegister_Click" Width="68" Height="30"
                            Background="#f3f4f6" Foreground="#6b7280" FontSize="12"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="8,4"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="登录" Click="BtnLogin_Click" Width="68" Height="30"
                            Background="{StaticResource Accent}" Foreground="White" FontSize="12"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="8,4"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="注销" Click="BtnLogout_Click" Width="68" Height="30"
                            Background="#fef2f2" Foreground="#ef4444" FontSize="12"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="8,4"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="lblAccountStatus" Text="" FontSize="11" Foreground="#10b981" Margin="0,0,0,4"/>
                <TextBlock Text="密码最小长度" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtMinPwdLen" Text="6" Width="80" Margin="0,0,0,12"
                         ToolTip="注册时用户名和密码的最小长度，可在 settings.json 中调整"/>
                <TextBlock Text="服务器地址" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtServerUrl" Text="" Margin="0,0,0,6"
                         ToolTip="服务器地址，默认 http://localhost:5080"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox x:Name="chkHostServer" Content="本机作为服务器" FontSize="13"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,16,0"/>
                    <TextBox x:Name="txtServerPort" Text="5080" Width="60" Margin="0,0,4,0"
                             ToolTip="端口" FontSize="13" VerticalContentAlignment="Center"/>
                    <TextBlock Text="端口" FontSize="11" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <CheckBox x:Name="chkAutoSync" Content="启用自动同步（每60秒）"
                          FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                <Button Content="🧹 立即清理旧数据" Click="BtnCleanOld_Click"
                        Background="#fef2f2" Foreground="#ef4444" FontSize="12"
                        Height="36" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                        Padding="16,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="取消" Click="BtnCancel_Click" Background="#f3f4f6"
                        Foreground="#6b7280" FontSize="13" Height="38" Width="80"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="保存" Click="BtnSave_Click" Background="{StaticResource Accent}"
                        Foreground="White" FontSize="13" FontWeight="SemiBold" Height="38" Width="80"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
