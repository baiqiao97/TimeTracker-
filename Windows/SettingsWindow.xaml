<Window x:Class="TimeTracker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="680" Width="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif"
        Background="#f5f6fa">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1a1d2e"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="Border" Color="#e5e7eb"/>
        <SolidColorBrush x:Key="Bg" Color="#f5f6fa"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#f9fafb"/>
            <Setter Property="BorderBrush" Value="#d1d5db"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6c5ce7"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1a1d2e"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16">

        <!-- 标题 -->
        <TextBlock Text="设置" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimary}" Margin="4,12,0,20"/>

        <!-- ===== 追踪设置 ===== -->
        <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22" Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="追踪设置" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="追踪间隔" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="前台窗口轮询间隔" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#f9fafb" CornerRadius="8" Padding="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtInterval" Text="2" Width="50" TextAlignment="Center"
                                     Background="Transparent" BorderThickness="0" Padding="4,6"/>
                            <TextBlock Text="秒" FontSize="13" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="2,0,4,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Height="1" Background="{StaticResource Border}" Margin="0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="数据保留" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="超过天数的旧记录自动清理" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Background="#f9fafb" CornerRadius="8" Padding="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="txtRetentionDays" Text="90" Width="50" TextAlignment="Center"
                                     Background="Transparent" BorderThickness="0" Padding="4,6"/>
                            <TextBlock Text="天" FontSize="13" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="2,0,4,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <CheckBox x:Name="chkAutoStart" Content="开机自动启动" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== 追踪模式 ===== -->
        <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22" Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="追踪模式" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbSimple" Content="标准模式" GroupName="trackMode"/>
                    <RadioButton x:Name="rbActivity" Content="活动模式" GroupName="trackMode"/>
                </StackPanel>
                <TextBlock Text="标准模式：按应用统一追踪 │ 活动模式：同一应用按不同活动独立追踪" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ===== 云同步 ===== -->
        <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22" Margin="0,0,0,12"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="云同步" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,14"/>

                <!-- 用户名密码输入 -->
                <TextBlock Text="账号" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtUsername" Margin="0,0,6,0" ToolTip="用户名"/>
                    <TextBox x:Name="txtPassword" Grid.Column="1" Margin="6,0,0,0" ToolTip="密码" CharacterCasing="Lower"/>
                </Grid>

                <!-- 按钮组 -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                    <Button Content="注册新账号" Click="BtnRegister_Click" Height="34" FontSize="12"
                            Background="#f3f4f6" Foreground="#6c5ce7" FontWeight="SemiBold"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#f3f4f6" CornerRadius="8" Padding="14,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#e8e4ff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="登录" Click="BtnLogin_Click" Height="34" FontSize="12" FontWeight="SemiBold"
                            Background="#6c5ce7" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#6c5ce7" CornerRadius="8" Padding="14,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="注销" Click="BtnLogout_Click" Height="34" FontSize="12" FontWeight="SemiBold"
                            Background="#fef2f2" Foreground="#ef4444" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="#fef2f2" CornerRadius="8" Padding="14,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#fee2e2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- 状态 -->
                <Border x:Name="accountStatusBorder" Background="#f0fdf4" CornerRadius="8" Padding="10,8" Margin="0,4,0,6">
                    <TextBlock x:Name="lblAccountStatus" Text="⚠ 未登录" FontSize="12" FontWeight="SemiBold"
                               Foreground="#f59e0b"/>
                </Border>

                <!-- 密码最小长度 -->
                <TextBlock Text="密码最小长度" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <Border Background="#f9fafb" CornerRadius="8" Padding="4,0" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="txtMinPwdLen" Text="6" Width="40" TextAlignment="Center"
                                 Background="Transparent" BorderThickness="0" Padding="4,6"
                                 ToolTip="可在 settings.json 中自行调整"/>
                        <TextBlock Text="位" FontSize="13" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="2,0,4,0"/>
                    </StackPanel>
                </Border>

                <Border Height="1" Background="{StaticResource Border}" Margin="0,12"/>

                <!-- 服务器地址 -->
                <TextBlock Text="服务器地址" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtServerUrl" Margin="0,0,0,10" ToolTip="默认 http://localhost:5080"/>

                <!-- 本机托管 + 端口 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="chkHostServer" Content="本机作为服务器" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="端口" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="txtServerPort" Text="5080" Width="60" FontSize="13" VerticalContentAlignment="Center"
                                 TextAlignment="Center" ToolTip="端口号"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="chkAutoSync" Content="启用自动同步（每60秒）" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- ===== 危险操作 ===== -->
        <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="22" Margin="0,0,0,16"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="数据维护" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                <Button Content="立即清理过期数据" Click="BtnCleanOld_Click"
                        Background="#fef2f2" Foreground="#ef4444" FontSize="12" FontWeight="SemiBold"
                        Height="38" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                        Padding="16,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#fef2f2" CornerRadius="10" Padding="16,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#fee2e2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,16">
            <Button Content="取消" Click="BtnCancel_Click" Background="#f3f4f6"
                    Foreground="#6b7280" FontSize="13" FontWeight="SemiBold" Height="40" Width="90"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#f3f4f6" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#e5e7eb"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="保存设置" Click="BtnSave_Click" Background="{StaticResource Accent}"
                    Foreground="White" FontSize="13" FontWeight="SemiBold" Height="40" Width="90"
                    BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</Window>
