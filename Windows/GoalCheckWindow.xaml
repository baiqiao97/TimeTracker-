<Window x:Class="TimeTracker.GoalCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="阶段检测" Height="520" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f5f6fa" FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
        <SolidColorBrush x:Key="CardBg" Color="#ffffff"/>
    </Window.Resources>

    <Border Background="{StaticResource CardBg}" CornerRadius="14" Margin="16"
            Effect="{DynamicResource CardShadow}">
        <StackPanel Margin="24">
            <TextBlock Text="📝 阶段检测" FontSize="20" FontWeight="Bold" Foreground="#1a1d2e" Margin="0,0,0,16"/>
            <TextBlock x:Name="lblGoalInfo" Text="" FontSize="14" Foreground="#6b7280" Margin="0,0,0,6"/>

            <TextBlock Text="实际投入时间（分钟）" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" Margin="0,12,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtMinutes" Text="120" FontSize="14" Padding="10,8" Background="#f9fafb"/>
                <TextBlock Grid.Column="1" Text="分钟" FontSize="13" Foreground="#6b7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <TextBlock Text="该阶段有效工作比" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtRatio" Text="0.5" FontSize="14" Padding="10,8" Background="#f9fafb"/>
                <TextBlock Grid.Column="1" Text="(0~1)" FontSize="13" Foreground="#6b7280" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>

            <TextBlock Text="目标数据佐证（该阶段追踪到的相关应用分钟数）" FontSize="12" FontWeight="SemiBold"
                       Foreground="#6b7280" Margin="0,0,0,4"/>
            <Border Background="#f0fdf4" CornerRadius="10" Padding="12,8" Margin="0,0,0,12">
                <TextBlock x:Name="lblTrackingData" Text="加载中..." FontSize="12" Foreground="#10b981" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="备注" FontSize="12" FontWeight="SemiBold" Foreground="#6b7280" Margin="0,0,0,4"/>
            <TextBox x:Name="txtNotes" Height="60" FontSize="13" Padding="10,8" Background="#f9fafb"
                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,14"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="🤖 AI 评价" x:Name="btnAiEval" Grid.Column="0" Height="40" Click="BtnAiEval_Click"
                        Background="#f3f4f6" Foreground="#6b7280" FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"
                        IsEnabled="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#f3f4f6" CornerRadius="10" Padding="16,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="取消" Grid.Column="1" Width="80" Height="40" Click="BtnCancel_Click"
                        Background="#f3f4f6" Foreground="#6b7280" FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="✅ 确认完成" Grid.Column="2" Width="120" Height="40" Click="BtnConfirm_Click"
                        Background="#6c5ce7" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- AI 评价结果 -->
            <Border x:Name="borderAiResult" Background="#f5f3ff" CornerRadius="10" Padding="14" Margin="0,12,0,0" Visibility="Collapsed">
                <TextBlock x:Name="lblAiResult" Text="" FontSize="12" Foreground="#6c5ce7" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
