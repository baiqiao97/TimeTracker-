<Window x:Class="TimeTracker.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="欢迎使用 TimeTracker" Height="420" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI, Microsoft YaHei UI, sans-serif">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#6c5ce7"/>
    </Window.Resources>
    <Border Background="White" CornerRadius="16">
        <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.15"/></Border.Effect>
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,8,0,20">
                <TextBlock Text="欢迎使用 TimeTracker" FontSize="24" FontWeight="Bold" Foreground="#1a1d2e"/>
                <TextBlock Text="智能时间管理专家" FontSize="14" Foreground="#6b7280" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Border Background="#f5f3ff" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="标准模式" FontSize="14" FontWeight="Bold" Foreground="#6c5ce7"/>
                        <TextBlock Text="按应用自动追踪使用时长，支持标签分类统计" FontSize="12" Foreground="#6b7280" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#f0fdf4" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="活动模式" FontSize="14" FontWeight="Bold" Foreground="#10b981"/>
                        <TextBlock Text="同一应用在不同活动（学习/工作/娱乐）下独立追踪" FontSize="12" Foreground="#6b7280" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#eff6ff" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="启动后可随时在设置中切换模式" FontSize="12" Foreground="#3b82f6"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="跳过" Click="BtnSkip_Click" Width="80" Height="40"
                        Background="#f3f4f6" Foreground="#6b7280" FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#f3f4f6" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="开始使用" Click="BtnStart_Click" Width="100" Height="40"
                        Background="#6c5ce7" Foreground="White" FontSize="13" FontWeight="SemiBold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#6c5ce7" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#5a4bd1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
