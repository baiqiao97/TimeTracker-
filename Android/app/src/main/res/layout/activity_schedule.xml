<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f5f6fa">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="日程安排"
        android:textSize="22sp"
        android:textColor="#1a1d2e"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="管理你的日程计划"
        android:textSize="13sp"
        android:textColor="#6b7280"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/etScheduleTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="日程标题"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="@drawable/edit_bg"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <DatePicker
                android:id="@+id/dpScheduleDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:calendarViewShown="false"
                android:datePickerMode="spinner"/>

            <EditText
                android:id="@+id/etScheduleTime"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:hint="08:00-10:00"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:background="@drawable/edit_bg"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <CheckBox
                android:id="@+id/chkAllDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="全天"/>

            <Spinner
                android:id="@+id/spColor"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:entries="@array/schedule_colors"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnAddSchedule"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="添加日程"
            android:textColor="#fff"
            android:backgroundTint="#6c5ce7"/>
    </LinearLayout>

    <ListView
        android:id="@+id/lvSchedules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="8dp"/>
</LinearLayout>
